// Copiez et collez l'intégralité du contenu ci-dessous dans :
// Console Firebase -> Votre Projet -> Firestore Database -> Onglet "Règles"
// Ensuite, cliquez sur "Publier".

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Un "admin" = un utilisateur connecté par email/mot de passe (PAS un visiteur anonyme).
    // Les participants du salon sont connectés en ANONYME : ils ne doivent PAS pouvoir
    // modifier le contenu d'administration (jeux, configs, slots, participants, résultats...).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Jeux : lecture publique ; écriture admin uniquement.
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Animateurs / auteurs : lecture publique ; écriture admin uniquement.
    match /animateurs/{animatorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurations de tables (gabarits) : lecture publique ; écriture admin uniquement.
    match /configurations/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Slots (configurations placées sur la grille) : lecture publique ; écriture admin uniquement.
    match /slots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Anciennes tables (modèle hérité) : lecture publique ; écriture admin uniquement.
    match /gameTables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inscriptions : lecture publique. Création/màj/suppression par tout utilisateur
    // authentifié, car les participants (anonymes) s'inscrivent eux-mêmes au salon.
    // Le contrôle métier (qui s'inscrit où) est géré côté application.
    match /registrations/{registrationId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Liste des participants : lecture publique (affichage des noms).
    // Écriture admin uniquement (la synchro Billetweb est lancée par l'admin connecté).
    match /liste_participants/{participantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Résultats des parties (Hall of Fame) : lecture publique ; écriture admin uniquement.
    match /gameResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Paramètres système (contrôle des inscriptions) : lecture publique ; écriture admin.
    match /system_settings/registrationControl {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Archives des éditions passées : lecture publique ; écriture admin uniquement.
    match /archives/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tout le reste est refusé par défaut.
  }
}
